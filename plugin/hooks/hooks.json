{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/session_start_context.py"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "mcp__ml-intern__ml-intern-tools__.*|Bash",
      "hooks": [
        {
          "type": "command",
          "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_use_approval.py"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/session_end_upload.py"
        }
      ]
    }
  ]
}
